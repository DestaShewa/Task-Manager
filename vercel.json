{
    "rewrites": [
        {
            "source": "/(assets|pwa-|manifest.webmanifest|vite.svg)(.*)",
            "destination": "/$1$2"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/users(.*)",
            "destination": "/api"
        },
        {
            "source": "/tasks(.*)",
            "destination": "/api"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}